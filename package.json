{
  "name": "playwright-api-template",
  "version": "2.0.0",
  "description": "Playwright API Testing Template with TypeScript and Best Practices",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test tests/api",
    "test:smoke": "playwright test tests/api/smoke",
    "test:integration": "playwright test tests/api/integration",
    "test:contract": "playwright test tests/api/contract",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "lint": "tsc --noEmit",
    "template:cleanup": "node scripts/template-cleanup.mjs",
    "rtk": ".\\rtk-x86_64-pc-windows-msvc\\rtk.exe",
    "rtk:version": ".\\rtk-x86_64-pc-windows-msvc\\rtk.exe --version",
    "mcp:context7": "npx -y @upstash/context7-mcp@latest",
    "install:browsers": "playwright install",
    "rules:sync:to-root": "node scripts/sync-rules.mjs to-root",
    "rules:sync:from-root": "node scripts/sync-rules.mjs from-root"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "contract-testing",
    "integration",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  }
}
