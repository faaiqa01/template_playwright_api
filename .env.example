# Environment Configuration Template
# Copy this file to .env and fill in actual values

NODE_ENV=dev
CI=false

# Core API target
API_BASE_URL=https://dummyjson.com
API_TOKEN=
API_TIMEOUT_MS=15000

# DummyJSON auth test account (from docs)
DUMMYJSON_USERNAME=emilys
DUMMYJSON_PASSWORD=emilyspass
DUMMYJSON_EXPIRES_IN_MINS=30

# Optional per environment overrides
DEV_API_BASE_URL=https://dummyjson.com
STAGING_API_BASE_URL=https://staging.example.com/api
PROD_API_BASE_URL=https://api.example.com

# Optional: Context7 API key
CONTEXT7_API_KEY=
